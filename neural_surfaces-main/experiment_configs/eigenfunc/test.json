{
    "datasets":
    {
        "train":
        {
            "name":"EigenfuncDataset",
            "num_points":10000,
            "sample_path":"../data/eigenfunc/SPHERE/samples.pth",
            "num_workers":8,
            "shuffle":true,
            "batch_size":null,
            "pin_memory":false,
            "mask_normals_type":"sphere"
        }
    },
    "models":
    {
        "name": "ResidualMLP",
        "structure": {
            "input_size": 3,
            "output_size": 3,
            "layers": [10,10],
            "act": "Softplus",
            "act_params": {},
            "bias": false,
            "init": "xavier",
            "norm":null,
            "drop":0.0
        }
    },
    "loss":
    {
        "name":"MSELoss",
        "params":
        {
            "reg_normals":1.0e-4
        }
    },
    "optimizers":
    [
        {
            "name":"RMSprop",
            "params":
            {
                "lr":1.0e-4,
                "momentum":0.9
            }
        }
    ],
    "schedulers": [],
    "tasks":
    {
        "name":"eigenfunc",
        "train":"EigenfuncTrainer",
        "checkpoint":"EigenfuncCheckpointer",
        "params":
        {
            "save_patches":false,
            "save_timelapse":false,
            "save_kaolin":false
        }
    },
    "logging":
    {
        "name":"TensorboardLogger",
        "namespace":"eigenfunc",
        "identifier":"25marOPTIM10",
        "base_path":"../logs/eigenfunc/SPHERE/",
        "identifier":"jrotjrb"
    },
    "checkpointing":
    {
        "base_path":"../checkpoints/eigenfunc/SPHERE/",
         "identifier":"jrotjrb"
    },
    "rendering":
    {
        "config":"../rendering_configs/giraffe.json"
    },
    "loop":
    {
        "name": "GradientTrainingLoop",
        "num_epochs":20000,
        "grad_stop":1.0e-8,
        "checkpoint_epoch":10
    }
}
